{
  "name": "@agent-os/core",
  "version": "0.1.0",
  "description": "Provider-neutral domain contracts for Agent OS",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @agent-os/app dev",
    "start": "pnpm --filter @agent-os/app start",
    "addCapability": "node --experimental-strip-types scripts/add-package.ts",
    "build:core": "tsc -p tsconfig.json",
    "build:packages": "pnpm --filter './packages/**' -r --if-present run build",
    "build": "pnpm run build:core && pnpm run build:packages",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^7.0.0"
  },
  "packageManager": "pnpm@11.16.0"
}
